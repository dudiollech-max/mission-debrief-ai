# Mission Debrief AI — Environment Configuration
# Copy this file to .env and fill in your values

# ─── OpenAI (optional but recommended) ───────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Local LLM via Ollama (alternative to OpenAI) ────────────────────────────
USE_LOCAL_LLM=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llava
OLLAMA_DEBRIEF_MODEL=llama3.2

# ─── Video Processing ─────────────────────────────────────────────────────────
MAX_FRAMES=20
FRAME_INTERVAL=15

# ─── Anomaly Detection ────────────────────────────────────────────────────────
ANOMALY_Z_THRESHOLD=2.5

# ─── Output ───────────────────────────────────────────────────────────────────
PDF_OUTPUT_DIR=./output/pdfs
UPLOAD_DIR=./uploads

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ─── CORS (add frontend URLs in production) ───────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
